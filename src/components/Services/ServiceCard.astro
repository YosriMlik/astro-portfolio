---
import TechIcon from '../UI/TechIcon.astro';

export interface Props {
  title: string;
  technologies: Array<{
    name: string;
    src: string;
  }>;
  isWide?: boolean;
}

const { title, technologies, isWide = false } = Astro.props;
---

<div class={`glass rounded-2xl p-6 border border-custom transition-all duration-300 ${isWide ? 'md:col-span-2' : ''}`}>
  <div class="flex items-center gap-4 mb-6">
    <div class="w-12 h-12 bg-gradient-to-br from-accent/20 to-accent-hover/10 rounded-full flex items-center justify-center">
      <i class="fas fa-code text-accent text-lg"></i>
    </div>
    <h3 class="text-xl font-bold text-primary">{title}</h3>
  </div>
  
  <div class={`grid gap-3 ${isWide ? 'grid-cols-4 md:grid-cols-6 lg:grid-cols-8' : 'grid-cols-3 md:grid-cols-4 lg:grid-cols-5'}`}>
    {technologies.map((tech) => (
      tech.name !== "" ? (
        <div class="flex items-center justify-center p-2 rounded-lg bg-tertiary/20 hover:bg-tertiary/30 transition-colors">
          <TechIcon {...tech} />
        </div>
      ) : null
    ))}
  </div>
</div>